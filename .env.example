# Copy this file to .env.local for LOCAL testing only.
# On Vercel, set these in Project → Settings → Environment Variables instead.

# Your Anthropic API key. Get it from https://console.anthropic.com → API Keys.
# This stays server-side only and is never sent to the browser.
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# These two are added AUTOMATICALLY when you connect Vercel KV to the project.
# You do NOT type them by hand — listed here only so you know what they are.
# KV_REST_API_URL=
# KV_REST_API_TOKEN=
